# ============================================================================
# 事故处理平台 - Nginx 反向代理配置参考
# ============================================================================
# 使用方法:
#   1. 复制到 /etc/nginx/sites-available/accident-platform
#   2. 修改 server_name 为你的域名
#   3. ln -s /etc/nginx/sites-available/accident-platform /etc/nginx/sites-enabled/
#   4. nginx -t && nginx -s reload
#
# 如果使用方案 B（FastAPI 直接托管前端），则不需要此配置，
# 在 .env 中设置 SERVE_STATIC=true 即可。
# ============================================================================

server {
    listen 80;
    server_name your-domain.com;   # ← 修改为你的域名

    # 前端静态文件（npm run build 生成的 dist/ 目录）
    root /path/to/accident_app/dist;   # ← 修改为实际路径
    index index.html;

    # 上传大小限制
    client_max_body_size 500M;

    # SPA 路由：所有非文件请求回退到 index.html
    location / {
        try_files $uri $uri/ /index.html;
    }

    # API 代理到 Python 后端
    location /api/ {
        proxy_pass http://127.0.0.1:8001;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 300s;
    }

    # 健康检查
    location /health {
        proxy_pass http://127.0.0.1:8001;
        proxy_set_header Host $host;
    }

    # 关键帧图片
    location /keyframes {
        proxy_pass http://127.0.0.1:8001;
        proxy_set_header Host $host;
    }

    # 上传视频
    location /uploaded_videos {
        proxy_pass http://127.0.0.1:8001;
        proxy_set_header Host $host;
    }

    # 临时文件
    location /temp {
        proxy_pass http://127.0.0.1:8001;
        proxy_set_header Host $host;
    }
}

# ============================================================================
# HTTPS 配置（推荐）:
#   使用 certbot 自动获取 SSL 证书:
#   certbot --nginx -d your-domain.com
# ============================================================================
