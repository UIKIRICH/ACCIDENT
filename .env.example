# ============================================================================
# 事故处理平台 - 环境变量配置示例
# ============================================================================
# 复制此文件为 .env 并修改配置

# ---------------------------------------------------------------------------
# 数据库配置
# ---------------------------------------------------------------------------
# SQLite（默认）:
DATABASE_URL=sqlite:///./accident_platform.db

# MySQL（生产环境示例）:
# DATABASE_URL=mysql+pymysql://user:password@host:3306/accident_db

# ---------------------------------------------------------------------------
# Dify LLM 集成配置
# ---------------------------------------------------------------------------
DIFY_BASE_URL=http://localhost:8000
DIFY_API_KEY=app-xxxxxxxxxxxx
DIFY_WORKFLOW_ENDPOINT=/v1/workflows/run
DIFY_TIMEOUT_SEC=60
DIFY_RESPONSE_MODE=blocking
DIFY_LOCAL_FALLBACK_ENABLED=true

# Dify 输入映射（通常无需修改）
# DIFY_INPUT_SUMMARY_KEY=summary_text
# DIFY_INPUT_VIDEO_JSON_KEY=video_result_json
# DIFY_INPUT_IMAGE_JSON_KEY=image_evidence_json
# DIFY_INPUT_EXTRA_KEY=additional_evidence

# ---------------------------------------------------------------------------
# JWT 密钥（生产环境请修改）
# ---------------------------------------------------------------------------
JWT_SECRET=accident-platform-secret-key-change-in-production

# ---------------------------------------------------------------------------
# 前端 API 地址
# ---------------------------------------------------------------------------
VITE_API_BASE_URL=/api